generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id           String         @id @default(uuid())
  fantasyName  String
  realName     String
  logo         String
  description  String
  collaborators Collaborator[]
  teams        Team[]
  systems      System[]
  vendors      Vendor[]
  contracts    Contract[]
  initiatives  Initiative[]
  allocations  Allocation[]
  departments  Department[]
}

model User {
  id                    String   @id @default(uuid())
  fullName              String
  email                 String   @unique
  password              String
  photoUrl              String?
  role                  String   @default("Engineer/Analyst")
  associatedCompanyIds  String[]
}

model Department {
  id           String         @id @default(uuid())
  name         String
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  collaborators Collaborator[]
  teams        Team[]
  systems      System[]
  vendors      Vendor[]
  contracts    Contract[]
  initiatives  Initiative[]
  allocations  Allocation[]
}

model Collaborator {
  id        String   @id @default(uuid())
  companyId String
  departmentId String
  company   Company  @relation(fields: [companyId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  name      String
  email     String   @unique
  role      String
  squadId   String?  @map("teamId")
  photoUrl  String?
  phone     String?
  bio       String?
  linkedinUrl String?
  githubUrl   String?
  skills    Json[]   // [{ skillId: string, level: string }]
}

model Team {
  id           String  @id @default(uuid())
  companyId    String
  departmentId String
  company      Company @relation(fields: [companyId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  name         String
  type         String
  parentTeamId String?
  leaderId     String?
}

model System {
  id               String   @id @default(uuid())
  companyId        String
  departmentId     String
  company          Company  @relation(fields: [companyId], references: [id])
  department       Department @relation(fields: [departmentId], references: [id])
  name             String
  platformName     String?
  domain           String
  subDomain        String?
  criticality      String
  techStack        String[]
  ownerTeamId      String?
  smeId            String?
  lifecycleStatus  String
  debtScore        Float    @default(0)
  description      String
  platformCategory String?
  vendorId         String?
  vendor           Vendor?  @relation("VendorSystems", fields: [vendorId], references: [id])
  repoUrl          String?
  environments     Json?
  contextFiles     Json?
}

model Vendor {
  id          String   @id @default(uuid())
  companyId   String
  departmentId String
  company     Company  @relation(fields: [companyId], references: [id])
  department  Department @relation(fields: [departmentId], references: [id])
  companyName String
  taxId       String
  type        String
  logoUrl     String?
  contracts   Contract[]
  systems     System[] @relation("VendorSystems")
}

model Contract {
  id         String   @id @default(uuid())
  companyId  String
  departmentId String
  company    Company  @relation(fields: [companyId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id])
  number     String
  startDate  String
  endDate    String
  model      String
  annualCost Float
}

model Initiative {
  id                     String               @id @default(uuid())
  companyId              String
  departmentId           String
  company                Company              @relation(fields: [companyId], references: [id])
  department             Department           @relation(fields: [departmentId], references: [id])
  title                  String
  type                   String
  benefit                String
  benefitType            String?
  scope                  String
  customerOwner          String
  originDirectorate      String
  leaderId               String
  technicalLeadId        String?
  impactedSystemIds      String[]
  createdAt              DateTime             @default(now())
  businessExpectationDate String?
  status                 String
  previousStatus         String?
  milestones             InitiativeMilestone[]
  history                InitiativeHistory[]
}

model InitiativeMilestone {
  id               String     @id @default(uuid())
  name             String
  systemId         String
  baselineDate     String
  realDate         String?
  description      String?
  assignedEngineerId String?
  startDate        String?
  initiativeId     String
  initiative       Initiative @relation(fields: [initiativeId], references: [id])
}

model InitiativeHistory {
  id           String     @id @default(uuid())
  timestamp    DateTime   @default(now())
  user         String
  action       String
  fromStatus   String?
  toStatus     String?
  notes        String?
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id])
}

model Allocation {
  id             String @id @default(uuid())
  companyId      String
  departmentId   String
  company        Company @relation(fields: [companyId], references: [id])
  department     Department @relation(fields: [departmentId], references: [id])
  collaboratorId String
  initiativeId   String
  systemId       String?
  percentage     Int
  startDate      String
  endDate        String
}
