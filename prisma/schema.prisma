generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Company {
  id            String         @id @default(uuid())
  fantasyName   String
  realName      String
  logo          String
  description   String
  allocations   Allocation[]
  collaborators Collaborator[]
  contracts     Contract[]
  departments   Department[]
  initiatives   Initiative[]
  systems       System[]
  teams         Team[]
  vendors       Vendor[]
  skills        Skill[]
}

model Department {
  id            String         @id @default(uuid())
  name          String
  companyId     String
  allocations   Allocation[]
  collaborators Collaborator[]
  contracts     Contract[]
  company       Company        @relation(fields: [companyId], references: [id])
  initiatives   Initiative[]
  systems       System[]
  teams         Team[]
  vendors       Vendor[]
  masterUserId  String?
  skills        Skill[]
}

model Collaborator {
  id           String     @id @default(uuid())
  companyId    String
  departmentId String
  name         String
  email        String     @unique
  role         String
  squadId      String?    @map("teamId")
  photoUrl     String?
  phone        String?
  bio          String?
  linkedinUrl  String?
  githubUrl    String?
  password     String     @default("123456")
  isAdmin      Boolean    @default(false)
  vacationStart String?   // format: YYYY-MM-DD
  startDate     String?   // format: YYYY-MM-DD
  endDate       String?   // format: YYYY-MM-DD
  associatedCompanyIds String[]   @default([])
  company      Company    @relation(fields: [companyId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  skills       CollaboratorSkill[]
  absences     Absence[]
}

model Absence {
  id             String       @id @default(uuid())
  collaboratorId String
  startDate      String       // YYYY-MM-DD
  endDate        String       // YYYY-MM-DD
  type           String       // Férias, Folga, Licença Médica, etc.
  reason         String?
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id @default(uuid())
  date      String   // YYYY-MM-DD
  name      String
  companyId String?  
}

model Skill {
  id           String             @id @default(uuid())
  name         String
  description  String
  familia      String?
  icon         String?
  companyId    String
  departmentId String
  company      Company            @relation(fields: [companyId], references: [id])
  department   Department         @relation(fields: [departmentId], references: [id])
  collaborators CollaboratorSkill[]
}

model CollaboratorSkill {
  collaboratorId String
  skillId        String
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id])
  skill          Skill        @relation(fields: [skillId], references: [id])

  @@id([collaboratorId, skillId])
}

model Team {
  id           String     @id @default(uuid())
  companyId    String
  departmentId String
  name         String
  type         String
  parentTeamId String?
  leaderId     String?
  receivesInitiatives Boolean    @default(false)
  company            Company    @relation(fields: [companyId], references: [id])
  department         Department @relation(fields: [departmentId], references: [id])
}

model System {
  id               String     @id @default(uuid())
  companyId        String
  departmentId     String
  name             String
  platformName     String?
  domain           String
  subDomain        String?
  criticality      String
  techStack        String[]
  ownerTeamId      String?
  smeId            String?
  lifecycleStatus  String
  debtScore        Float      @default(0)
  description      String
  platformCategory String?
  vendorId         String?
  repoUrl          String?
  environments     Json?
  contextFiles     Json?
  company          Company    @relation(fields: [companyId], references: [id])
  department       Department @relation(fields: [departmentId], references: [id])
  vendor           Vendor?    @relation("VendorSystems", fields: [vendorId], references: [id])
}

model Vendor {
  id           String     @id @default(uuid())
  companyId    String
  departmentId String
  companyName  String
  taxId        String
  type         String
  logoUrl      String?
  directorId   String?
  managerId    String?
  contracts    Contract[]
  systems      System[]   @relation("VendorSystems")
  company      Company    @relation(fields: [companyId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
}

model Contract {
  id           String     @id @default(uuid())
  companyId    String
  departmentId String
  vendorId     String
  number       String
  startDate    String
  endDate      String
  model        String
  annualCost   Float
  company      Company    @relation(fields: [companyId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  vendor       Vendor     @relation(fields: [vendorId], references: [id])
}

model Initiative {
  id                      String                @id @default(uuid())
  companyId               String
  departmentId            String
  title                   String
  type                    String
  benefit                 String
  benefitType             String?
  scope                   String
  customerOwner           String
  originDirectorate       String
  leaderId                String
  technicalLeadId         String?
  impactedSystemIds       String[]
  createdAt               DateTime              @default(now())
  requestDate             String?
  businessExpectationDate String?
  status                  String
  previousStatus          String?
  executingTeamId         String?
  executingDirectorate    String?
  rationale               String?
  externalLinkType        String?
  externalLinkName        String?
  externalLinkUrl         String?
  macroScope             String[]
  createdById             String?
  assignedManagerId       String?
  initiativeType         String?
  priority               Int                   @default(0)
  memberIds              String[]
  startDate              String?
  endDate                String?
  actualEndDate          String?
  company                 Company               @relation(fields: [companyId], references: [id])
  department              Department            @relation(fields: [departmentId], references: [id])
  history                 InitiativeHistory[]
  milestones              InitiativeMilestone[]
  comments                InitiativeComment[]
}

model InitiativeMilestone {
  id                 String     @id @default(uuid())
  name               String
  systemId           String
  baselineDate       String
  realDate           String?
  description        String?
  assignedEngineerId String?
  startDate          String?
  order              Int?
  initiativeId       String
  initiative         Initiative @relation(fields: [initiativeId], references: [id])
  tasks              MilestoneTask[]
}

model MilestoneTask {
  id                 String              @id @default(uuid())
  name               String
  status             String              @default("Backlog") // Backlog, In Progress, Done
  type               String?             // Feature, Melhoria, Bug, Debito Técnico, Enabler
  assigneeId         String?             // member of team
  systemId           String?             
  startDate          String?             // YYYY-MM-DD
  targetDate         String?             // YYYY-MM-DD
  notes              String?             // Descrição da tarefa
  order              Int                 // Ordem de exibição
  milestoneId        String
  milestone          InitiativeMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model InitiativeHistory {
  id           String     @id @default(uuid())
  timestamp    DateTime   @default(now())
  user         String
  action       String
  fromStatus   String?
  toStatus     String?
  notes        String?
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id])
}

model InitiativeComment {
  id           String     @id @default(uuid())
  content      String
  userId       String
  userName     String
  userPhoto    String?
  timestamp    DateTime   @default(now())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
}

model Allocation {
  id             String     @id @default(uuid())
  companyId      String
  departmentId   String
  collaboratorId String
  initiativeId   String
  systemId       String?
  percentage     Int
  startDate      String
  endDate        String
  company        Company    @relation(fields: [companyId], references: [id])
  department     Department @relation(fields: [departmentId], references: [id])
}
